{
    "info": {
        "name": "Loan Management API",
        "description": "Endpoints for the Java Spring Boot Loan Management application.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "User APIs",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secure123\",\n  \"role\": \"USER\"\n}"
                        },
                        "url": {"raw": "http://localhost:8080/api/users/register", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "users", "register"]}
                    }
                },
                {
                    "name": "Login User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secure123\"\n}"
                        },
                        "url": {"raw": "http://localhost:8080/api/users/login", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "users", "login"]}
                    }
                }
            ]
        },
        {
            "name": "Loan APIs",
            "item": [
                {
                    "name": "Apply for Loan",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 5000.00,\n  \"termMonths\": 12,\n  \"userId\": 1\n}"
                        },
                        "url": {"raw": "http://localhost:8080/api/loans/apply", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "loans", "apply"]}
                    }
                },
                {
                    "name": "Get User Loans",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {"raw": "http://localhost:8080/api/loans/user/1", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "loans", "user", "1"]}
                    }
                },
                {
                    "name": "Update Loan Status",
                    "request": {
                        "method": "PUT",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/loans/1/status?status=APPROVED",
                            "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "loans", "1", "status"],
                            "query": [{"key": "status", "value": "APPROVED"}]
                        }
                    }
                }
            ]
        },
        {
            "name": "Payment APIs",
            "item": [
                {
                    "name": "Make EMI Payment",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 450.00,\n  \"loanId\": 1\n}"
                        },
                        "url": {"raw": "http://localhost:8080/api/payments", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "payments"]}
                    }
                },
                {
                    "name": "Get Loan Payments",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {"raw": "http://localhost:8080/api/payments/loan/1", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "payments", "loan", "1"]}
                    }
                }
            ]
        }
    ]
}
